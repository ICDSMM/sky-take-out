<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.sky.mapper.DishFlavorMapper">

    <!--批量插入-->
    <insert id="insertBatch">insert into dish_flavor (dish_id, name, value) VALUES
        <!--flavors是需要遍历的集合，item每次迭代中给当前元素指定的一个变量名，separator是用什么符号分割每次循环-->
        <foreach collection="flavors" item="df" separator=",">
            (#{df.dishId}, #{df.name}, #{df.value})
        </foreach>
    </insert>

    <!--更新单条口味信息-->
    <update id="update" parameterType="com.sky.entity.DishFlavor">
        update dish_flavor
        <set>
            <if test="dishId != null">dish_id = #{dishId},</if>
            <if test="name != null">name = #{name},</if>
            <if test="value != null">value = #{value},</if>
        </set>
        where id = #{id}
    </update>

    <!--根据菜品id删除对应口味-->
    <delete id="deleteByDishId">
        delete from dish_flavor where dish_id in
        <foreach collection="dishIds" item="dishId" separator="," open="(" close=")">#{dishId}</foreach>
    </delete>

    <!--根据菜品id查找对应口味-->
    <select id="getByDishId" resultType="com.sky.entity.DishFlavor">
        select * from dish_flavor where dish_id = #{dishId}
    </select>

</mapper>
