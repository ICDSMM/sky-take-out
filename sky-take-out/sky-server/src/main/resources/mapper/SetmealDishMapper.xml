<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.sky.mapper.SetmealDishMapper">
    <!--新增套餐与菜品关联-->
    <insert id="insert">
        insert into setmeal_dish (setmeal_id, dish_id, name, price, copies)
        VALUES (#{setmealId}, #{dishId}, #{name}, #{price}, #{copies})
    </insert>

    <!--删除套餐与菜品关联-->
    <delete id="deleteBySetmealIds">
        delete from setmeal_dish where setmeal_id in
        <foreach collection="ids" item="setmealId" open="(" close=")" separator=",">#{setmealId}</foreach>
    </delete>

    <!--根据菜品id查询关联的套餐id-->
    <select id="getSetmealIdByDishIds" resultType="java.lang.Long">
        select setmeal_id from setmeal_dish where dish_id in
        <foreach collection="dishIds" item="dishId" separator="," open="(" close=")">#{dishId}</foreach>
    </select>

    <!--根据套餐id查询-->
    <select id="getBySetmealId" resultType="com.sky.entity.SetmealDish">
        select * from setmeal_dish where setmeal_id = #{setmealId}
    </select>

</mapper>
